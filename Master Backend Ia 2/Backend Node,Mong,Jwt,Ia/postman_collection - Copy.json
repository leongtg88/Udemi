                            {
                                "key": "Authorization",
                                "value": "{{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Juan\",\n  \"surname\": \"Pérez\",\n  \"nick\": \"juanp\",\n  \"email\": \"juan@example.com\",\n  \"bio\": \"Backend developer actualizado\"\n}"
