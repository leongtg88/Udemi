                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"id\": \"<ARTICLE_ID>\",\n  \"title\": \"Título actualizado\",\n  \"content\": \"Contenido actualizado del artículo.\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/article/update",
                            "host": [
