                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Juan\",\n  \"surname\": \"Pérez\",\n  \"nick\": \"juanp\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"password123\",\n  \"bio\": \"Desarrollador backend\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/user/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
